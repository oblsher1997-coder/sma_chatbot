# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# DeepSeek API key from platform.deepseek.com
DEEPSEEK_API_KEY=

# Telegram group/channel ID where teacher notifications are sent
# Must be a number, e.g. -1001234567890
TEACHER_GROUP_CHAT_ID=

# Your personal Telegram chat ID — only this account can use /stats
ADMIN_CHAT_ID=

# Google Sheets integration (optional)
# Spreadsheet ID from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_ID=
