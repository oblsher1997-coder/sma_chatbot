# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# DeepSeek API key from platform.deepseek.com
DEEPSEEK_API_KEY=

# Telegram group/channel ID where teacher notifications are sent
# Must be a number, e.g. -1001234567890
TEACHER_GROUP_CHAT_ID=

# Payment links (replace with real ones from Payme/Click merchant panel)
PAYME_LINK=https://payme.uz/checkout/your-merchant-id
CLICK_LINK=https://my.click.uz/services/pay?service_id=YOUR_ID

# Your personal Telegram chat ID — only this account can use /stats
# Leave empty to allow anyone (not recommended for production)
ADMIN_CHAT_ID=
